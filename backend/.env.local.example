# Backend Environment Variables
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Claude API
ANTHROPIC_API_KEY=

# Helius
HELIUS_API_KEY=
HELIUS_WEBHOOK_ID=
HELIUS_WEBHOOK_SECRET=

# Codex (Token metadata API)
CODEX_API_KEY=

# Zerion API (wallet balance charts for agent PnL)
ZERION_API_KEY=

# Resend
RESEND_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Server Config
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Rate Limiting
# Trust proxy hops (1 for production behind Railway/Vercel, 0 for local dev)
TRUST_PROXY_HOPS=1
# Baseline API rate limit (15 min window)
RATE_LIMIT_API_WINDOW_MS=900000
RATE_LIMIT_API_MAX=250
# Write operations (POST/DELETE)
RATE_LIMIT_WRITE_MAX=50
# Registration endpoints
RATE_LIMIT_REGISTER_MAX=15
# PnL endpoint (expensive Zerion calls)
RATE_LIMIT_PNL_MAX=100
