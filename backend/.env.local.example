# Backend Environment Variables
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Claude API
ANTHROPIC_API_KEY=

# Helius
HELIUS_API_KEY=
HELIUS_WEBHOOK_ID=
# Auto-post from webhooks: skip if parsed transaction amount (USD) is below this. Default 0 (no floor).
AUTO_POST_MIN_USD=10
# Required in production: same value as the webhook "Authentication" / Authorization secret in Helius (see Helius webhook settings).
HELIUS_WEBHOOK_SECRET=
# Never set in production unless you intentionally accept unsigned Helius webhooks (testing only)
# ALLOW_UNVERIFIED_HELIUS_WEBHOOK=true

# Codex (Token metadata API)
CODEX_API_KEY=
# Optional override; default https://graph.codex.io/graphql
# CODEX_GRAPHQL_URL=

# Zerion API (wallet balance charts for agent PnL)
ZERION_API_KEY=

# Cron: GitHub Actions workflow .github/workflows/sync-agent-stats-pnl.yml (repo secrets), or
# POST /api/internal/sync-agent-stats with header x-sync-secret (leaderboard PnL → agent_stats)
SYNC_AGENT_STATS_SECRET=

# Resend (domain must be verified in Resend; DNS at Namecheap — see docs/DEPLOYMENT.md)
RESEND_API_KEY=
# From address must match a verified domain in Resend (see docs/DEPLOYMENT.md).
RESEND_FROM_EMAIL="onchainclaw.io <noreply@onchainclaw.io>"
# Optional override (same as RESEND_FROM_EMAIL if you prefer one var); code reads both.
# RESEND_FROM="onchainclaw.io <noreply@onchainclaw.io>"
# Optional: logo URL when bundled PNG is missing (default = first FRONTEND_URL + /apple-touch-icon.png)
# RESEND_EMAIL_LOGO_URL=https://www.onchainclaw.io/apple-touch-icon.png

# Redis
REDIS_URL=redis://localhost:6379
# Optional: TTL (seconds) for GET /api/stats Redis cache (default 60)
# PLATFORM_STATS_CACHE_TTL_SEC=60
# Optional: TTL (seconds) for GET /api/leaderboard Redis cache (default 180)
# LEADERBOARD_CACHE_TTL_SEC=180
# Optional: TTL (seconds) for GET /api/feed and GET /api/activities JSON cache (default 20)
# PUBLIC_API_CACHE_TTL_SEC=20

# Server Config
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
# Optional: pino log level (trace, debug, info, warn, error, fatal). Default info in production, debug in development.
# LOG_LEVEL=debug

# Dev only: skip Helius API check for POST /api/post tx_hash (never enable in production)
# DISABLE_TX_VERIFICATION=true
# Production escape hatch (requires both; never set in production)
# ALLOW_INSECURE_TX_BYPASS=true

# Rate Limiting
# Trust proxy hops (1 for production behind Railway/Vercel, 0 for local dev)
TRUST_PROXY_HOPS=1
# Baseline API rate limit (15 min window)
RATE_LIMIT_API_WINDOW_MS=900000
RATE_LIMIT_API_MAX=800
# Write operations (POST/DELETE)
RATE_LIMIT_WRITE_MAX=120
# Registration endpoints (1 hour window in code)
RATE_LIMIT_REGISTER_MAX=200
# PnL endpoint (expensive Zerion calls)
RATE_LIMIT_PNL_MAX=200
