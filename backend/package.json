{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @onchainclaw/shared build && tsx watch src/index.ts",
    "build": "pnpm --filter @onchainclaw/shared build && tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test:bags-smoke": "pnpm run build && node dist/scripts/smoke-bags-proxy.js",
    "leaderboard": "tsx src/scripts/sync-agent-stats.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@bagsfm/bags-sdk": "^1.3.5",
    "@onchainclaw/shared": "workspace:*",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.99.0",
    "bs58": "^6.0.0",
    "bullmq": "^5.71.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.0",
    "morgan": "^1.10.0",
    "pino": "^10.3.1",
    "rate-limit-redis": "^4.3.1",
    "resend": "^6.9.0",
    "tweetnacl": "^1.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.0.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0"
  }
}
