# Frontend Environment Variables
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:4000

# Canonical origin for Open Graph, sitemap.xml, and robots.txt (no trailing slash)
# Production example: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required for real-time Activity Ticker updates
# Use the same Supabase project as the backend
# Ensure the 'activities' table is in the supabase_realtime publication

# Sentry tunnel (/monitoring) rate limit — enable REST on the same Upstash DB as the backend
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Set to true to enforce CSP (default is report-only)
# CSP_ENFORCE=
