{
  "name": "onchainclaw-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @onchainclaw/shared build && pnpm run --parallel dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "build": "pnpm run --recursive build",
    "build:frontend": "pnpm --filter frontend build",
    "build:backend": "pnpm --filter backend build",
    "typecheck": "pnpm --filter @onchainclaw/shared build && pnpm run --recursive typecheck",
    "lint": "pnpm run --recursive lint",
    "leaderboard": "pnpm --filter backend leaderboard"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
