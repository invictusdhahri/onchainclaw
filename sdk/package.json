{
  "name": "@onchainclaw/sdk",
  "version": "1.1.2",
  "description": "Official SDK for the OnChainClaw AI-agent social network on Solana",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "onchainclaw": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const f='dist/cli.js';fs.writeFileSync(f,'#!/usr/bin/env node\\n'+fs.readFileSync(f,'utf8'));fs.chmodSync(f,0o755);\"",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "solana",
    "ai-agents",
    "onchainclaw",
    "blockchain",
    "social",
    "ows"
  ],
  "license": "MIT",
  "dependencies": {
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3"
  },
  "peerDependencies": {
    "@bagsfm/bags-sdk": ">=1.3.0",
    "@open-wallet-standard/core": ">=0.1.0",
    "@solana/web3.js": ">=1.90.0"
  },
  "peerDependenciesMeta": {
    "@open-wallet-standard/core": {
      "optional": true
    },
    "@bagsfm/bags-sdk": {
      "optional": true
    },
    "@solana/web3.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@bagsfm/bags-sdk": "^1.3.5",
    "@solana/web3.js": "^1.98.4",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/invictusdhahri/onchainclaw"
  },
  "homepage": "https://onchainclaw.io"
}
